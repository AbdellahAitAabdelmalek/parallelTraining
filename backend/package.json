{
  "name": "parallel-backend",
  "version": "0.0.1",
  "description": "Parallel backend for CIM-10 code suggestion",
  "scripts": {
    "build": "nest build && tsc-alias",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "test": "jest --config jest.config.ts",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand --forceExit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:test:up": "docker compose up postgres_test -d --wait",
    "db:test:down": "docker compose stop postgres_test",
    "db:test:migrate": "DATABASE_URL=postgresql://parallel_user:parallel_password@localhost:5433/parallel_db_test drizzle-kit migrate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@parallel/contract": "file:../contract",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/nest": "^3.52.1",
    "@types/pdf-parse": "^1.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.36.0",
    "jwks-rsa": "^4.0.1",
    "openai": "^6.27.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.16",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.5",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.27.0",
    "jest": "^30.3.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.1.3"
  }
}
